# SafeNet SA Environment Variables
# Copy this file to .env.local and fill in your values

# Firebase Configuration (SafeNet SA project only!)
# Create a new Firebase project at https://console.firebase.google.com
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=safenet-sa.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=safenet-sa
VITE_FIREBASE_STORAGE_BUCKET=safenet-sa.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here

# Luna AI API Endpoints
# These are the HTTPS endpoints SafeNet SA calls to use Luna AI features
# No shared database - API calls only over HTTPS
VITE_LUNA_BASE_URL=https://meet-luna-ai.vercel.app
VITE_LUNA_PHISHING_URL_ENDPOINT=/api/scan
VITE_LUNA_TEXT_ANALYSIS_ENDPOINT=/api/phish-text
VITE_LUNA_CHAT_ENDPOINT=/api/chat
VITE_LUNA_VOICE_ENDPOINT=/api/tts
VITE_LUNA_DIGEST_ENDPOINT=/api/weekly-digest
