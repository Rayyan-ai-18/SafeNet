# SafeNet SA Environment Variables
# Copy this file to .env.local and fill in your values

# Firebase Configuration (SafeNet SA project only!)
# Create a new Firebase project at https://console.firebase.google.com
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=safenet-sa.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=safenet-sa
VITE_FIREBASE_STORAGE_BUCKET=safenet-sa.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here

# Supabase — single source of truth (shared with the Luna-AI product).
# The app stays on bundled demo data until BOTH of these are set.
# Create a project at https://supabase.com, then run safenet-sa/supabase/schema.sql.
# Phone OTP sign-in requires enabling an SMS provider in Supabase Auth settings.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service-role key — SERVER-SIDE ONLY (no VITE_ prefix). Bypasses RLS; used by the
# Paystack webhook to activate a paid plan. NEVER expose this to the browser.
# Set in Vercel env. SUPABASE_URL/SUPABASE_ANON_KEY fall back to the VITE_ ones.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Paystack — ZAR card billing. Public key is client-safe; secret key is server-only.
# Create keys at https://dashboard.paystack.com/#/settings/developers
# Add the webhook URL https://your-domain/api/paystack-webhook in the Paystack dashboard.
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here

# Luna AI API Endpoints
# These are the HTTPS endpoints SafeNet SA calls to use Luna AI features
# No shared database - API calls only over HTTPS
VITE_LUNA_BASE_URL=https://meet-luna-ai.vercel.app
VITE_LUNA_PHISHING_URL_ENDPOINT=/api/scan
VITE_LUNA_TEXT_ANALYSIS_ENDPOINT=/api/phish-text
VITE_LUNA_CHAT_ENDPOINT=/api/chat
VITE_LUNA_VOICE_ENDPOINT=/api/tts
VITE_LUNA_DIGEST_ENDPOINT=/api/weekly-digest

# OpenRouter API Key — powers Luna's brain (the chat/LLM).
# SERVER-SIDE ONLY (no VITE_ prefix) so it never ships to the browser.
# Set this in the Vercel project's Environment Variables.
# Get a key at: https://openrouter.ai/keys
# Optionally override the model (default: meta-llama/llama-3.3-70b-instruct)
OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# PostHog analytics + experiments (client-side, so VITE_ prefix is intentional).
# Analytics is inert until this key is set. Create a free project at posthog.com.
VITE_POSTHOG_KEY=your_posthog_project_key_here
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Vulavula (Lelapa AI) — isiZulu speech-to-text for Luna (api/luna-transcribe.js).
# SERVER-SIDE ONLY. Used when the parent speaks isiZulu; English uses the
# browser's recognition. Get a key at https://vulavula.lelapa.ai
VULAVULA_API_KEY=your_vulavula_api_key_here
