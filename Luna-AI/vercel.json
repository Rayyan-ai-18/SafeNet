{
  "crons": [
    { "path": "/api/monitor-sweep", "schedule": "*/10 * * * *" },
    { "path": "/api/weekly-digest", "schedule": "0 9 * * 0" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "credentialless" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/team", "destination": "/api/enterprise-contact" },
    { "source": "/api/team/:path*", "destination": "/api/enterprise-contact" },
    { "source": "/status/:id", "destination": "/status.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
